# ─── Frontend ─────────────────────────────────────────────────────────────────
# Bỏ trống hoặc xóa dòng này để chạy static/localStorage (không cần backend)
VITE_API_URL=http://127.0.0.1:8787

# Data backend: supabase (production/default), api (Express/SQLite local), local (static demo)
VITE_DATA_BACKEND=supabase

# ─── Supabase Frontend ────────────────────────────────────────────────────────
# Dùng publishable key (sb_publishable_*) — an toàn ở browser, RLS bảo vệ data.
# KHÔNG bao giờ đưa secret key (sb_secret_*) vào đây hoặc Netlify env.
VITE_SUPABASE_URL=https://czxoozwydvmjisydyims.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_su1zQoGPpEdoUTzvuVFc4g_k1ksLyjo

# ─── Backend API ───────────────────────────────────────────────────────────────
MAIKA_API_HOST=127.0.0.1
MAIKA_API_PORT=8787
MAIKA_DB_PATH=server/data/maika.sqlite
MAIKA_UPLOAD_DIR=server/uploads
MAIKA_BACKUP_DIR=server/backups

# ─── Auth & Security ───────────────────────────────────────────────────────────
# QUAN TRỌNG: Đổi thành chuỗi ngẫu nhiên dài (>=32 ký tự) trước khi deploy!
MAIKA_JWT_SECRET=change-this-long-random-secret
MAIKA_ADMIN_PASSWORD=change-admin-password
MAIKA_TEACHER_PASSWORD=change-teacher-password
MAIKA_TOKEN_TTL=8h

# ─── CORS (production) ─────────────────────────────────────────────────────────
# Chỉ liệt kê domain thật khi deploy, không để * cho production
MAIKA_CORS_ORIGIN=http://127.0.0.1:5173,http://127.0.0.1:4173

# ─── Lịch Backup Tự Động ──────────────────────────────────────────────────────
# Đặt true để bật backup tự động theo lịch
MAIKA_BACKUP_SCHEDULE_ENABLED=false
# Cron expression (mặc định: 2:00 sáng mỗi ngày — Asia/Ho_Chi_Minh)
MAIKA_BACKUP_CRON=0 2 * * *
# Giữ tối đa N bản backup gần nhất
MAIKA_BACKUP_RETENTION_COUNT=30
# Xóa backup cũ hơn N ngày
MAIKA_BACKUP_RETENTION_DAYS=30
